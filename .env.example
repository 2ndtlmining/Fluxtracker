# ============================================
# Database Mode (sqlite or supabase, default: supabase)
# ============================================
# DB_TYPE=sqlite
# DB_PATH=data/fluxtracker.sqlite3

# ============================================
# Supabase (required when DB_TYPE=supabase or unset)
# ============================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Direct PostgreSQL connection for DDL migrations
# SUPABASE_DB_URL=

# Optional: Failover Supabase instance (auto-switch when primary is unreachable)
# SUPABASE_FAILOVER_URL=
# SUPABASE_FAILOVER_KEY=

# ============================================
# Cloudflare R2 Backup (primary instance only)
# All 4 required to enable automatic backups to R2
# ============================================
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# ============================================
# Bootstrap from R2 (Docker/SQLite instances only)
# Downloads latest backup on first start when DB is empty
# Use separate read-only R2 credentials for safety
# ============================================
# BOOTSTRAP_R2_ENDPOINT=
# BOOTSTRAP_R2_ACCESS_KEY_ID=
# BOOTSTRAP_R2_SECRET_ACCESS_KEY=
# BOOTSTRAP_R2_BUCKET_NAME=
